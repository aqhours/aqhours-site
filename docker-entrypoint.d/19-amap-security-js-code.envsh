#!/bin/sh

# The official Nginx entrypoint sources executable .envsh files before it renders
# templates, so this exported value remains available to its envsubst step.
set -eu

secret_path="/run/secrets/amap_security_js_code"

if [ -n "${AMAP_SECURITY_JS_CODE:-}" ]; then
  export AMAP_SECURITY_JS_CODE
elif [ -s "$secret_path" ]; then
  export AMAP_SECURITY_JS_CODE="$(cat "$secret_path")"
else
  echo "AMap security code secret is missing." >&2
  exit 1
fi
