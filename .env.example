# Select the map implementation at build time. Use `google` only when switching back.
NEXT_PUBLIC_MAP_PROVIDER=amap

# Public browser key. Restrict it to the local development origin in AMap Console.
NEXT_PUBLIC_AMAP_API_KEY=your_amap_javascript_api_key

# Local development only. Do not set this in the production Docker environment.
# Production sends the security code through the Nginx proxy secret instead.
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=your_amap_security_js_code

# Optional Google Maps fallback. These are public browser settings and only take effect when
# NEXT_PUBLIC_MAP_PROVIDER=google. Restrict the browser key to the relevant site origins.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_google_maps_map_id

# Umami tracking code values from the website's Settings page.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
